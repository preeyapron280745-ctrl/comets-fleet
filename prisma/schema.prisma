generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Employee {
  id         Int       @id @default(autoincrement())
  name       String
  department String?
  color      String    @default("#0ea5a0")
  active     Boolean   @default(true)
  bookings   Booking[]
  createdAt  DateTime  @default(now())
}

model Driver {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  color     String    @default("#e8a020")
  active    Boolean   @default(true)
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Car {
  id       Int       @id @default(autoincrement())
  plate    String    @unique
  type     String
  icon     String    @default("🚗")
  active   Boolean   @default(true)
  bookings Booking[]
}

model Location {
  id      Int    @id @default(autoincrement())
  name    String
  address String?
  mapUrl  String?
}

model Booking {
  id            Int          @id @default(autoincrement())
  date          String       // YYYY-MM-DD
  startTime     String       // HH:mm
  returnTime    String?      // HH:mm
  fromLocation  String
  toLocation    String
  passengers    String
  purpose       String
  purposeDetail String?
  status        String        @default("PENDING")
  tripStatus    String        @default("NOT_STARTED")

  employee      Employee      @relation(fields: [employeeId], references: [id])
  employeeId    Int

  driver        Driver?       @relation(fields: [driverId], references: [id])
  driverId      Int?

  car           Car?          @relation(fields: [carId], references: [id])
  carId         Int?

  rejectReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}


model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt hash
  name      String
  createdAt DateTime @default(now())
}
